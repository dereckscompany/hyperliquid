\subsection{Method \code{get_user_volume()}}{
Retrieve the account's daily traded volume. Sibling of
\link[=HyperliquidAccount]{get_user_fees()} over the same payload.
\subsection{Usage}{
\if{html}{\out{<div class="r">}}\preformatted{HyperliquidAccount$get_user_volume(address = private$.acting_address())}\if{html}{\out{</div>}}
}

\subsection{Arguments}{
\if{html}{\out{<div class="arguments">}}
\describe{
\item{\code{address}}{(scalar<character>) the account's \verb{0x}-prefixed address.
Defaults to the instance's acting address.}
}
\if{html}{\out{</div>}}
}
\subsection{Returns}{
(promise<data.table>) a \link[data.table:data.table]{data.table::data.table}, one row per day
(or a promise thereof):
\itemize{
\item date (character) the calendar day (\code{YYYY-MM-DD}).
\item exchange (numeric) the exchange-wide volume that day.
\item user_add (numeric) the user's maker (add) volume that day.
\item user_cross (numeric) the user's taker (crossing) volume that day.
}
}
}
