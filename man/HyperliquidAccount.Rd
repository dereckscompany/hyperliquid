\if{latex}{\out{\hypertarget{method-HyperliquidAccount-get_sub_accounts}{}}}
\subsection{Method \code{get_sub_accounts()}}{
Retrieve the account's sub-accounts (returns a zero-row table
when the account has none).
\subsection{Usage}{
\if{html}{\out{<div class="r">}}\preformatted{HyperliquidAccount$get_sub_accounts(address = private$.acting_address())}\if{html}{\out{</div>}}
}

\subsection{Arguments}{
\if{html}{\out{<div class="arguments">}}
\describe{
\item{\code{address}}{Character; the account's \verb{0x}-prefixed address. Defaults to
the instance's acting address.}
}
\if{html}{\out{</div>}}
}
\subsection{Returns}{
A \link[data.table:data.table]{data.table::data.table} with \code{name}, \code{sub_account_user},
\code{master}, \code{account_value}, \code{total_ntl_pos}, \code{total_raw_usd},
\code{total_margin_used}, \code{withdrawable}, or a promise thereof.
}
}
\if{html}{\out{<hr>}}
\if{html}{\out{<a id="method-HyperliquidAccount-get_order_status"></a>}}
\if{latex}{\out{\hypertarget{method-HyperliquidAccount-get_order_status}{}}}
\subsection{Method \code{get_order_status()}}{
Retrieve the status of a single order by its order id or
client order id.
\subsection{Usage}{
\if{html}{\out{<div class="r">}}\preformatted{HyperliquidAccount$get_order_status(
  address = private$.acting_address(),
  oid_or_cloid
)}\if{html}{\out{</div>}}
}

\subsection{Arguments}{
\if{html}{\out{<div class="arguments">}}
\describe{
\item{\code{address}}{Character; the account's \verb{0x}-prefixed address. Defaults to
the instance's acting address.}

\item{\code{oid_or_cloid}}{Numeric order id, or character \verb{0x}-prefixed client
order id (cloid).}
}
\if{html}{\out{</div>}}
}
\subsection{Returns}{
A single-row \link[data.table:data.table]{data.table::data.table} with \code{query_status} and the
order shape (\code{oid}, \code{coin}, \code{side}, ..., \code{status}, \code{status_timestamp}),
or a promise thereof.
}
}
\if{html}{\out{<hr>}}
\if{html}{\out{<a id="method-HyperliquidAccount-get_user_vault_equities"></a>}}
\if{latex}{\out{\hypertarget{method-HyperliquidAccount-get_user_vault_equities}{}}}
\subsection{Method \code{get_user_vault_equities()}}{
Retrieve the account's equity in each vault it has deposited
into, one row per vault.
\subsection{Usage}{
\if{html}{\out{<div class="r">}}\preformatted{HyperliquidAccount$get_user_vault_equities(address = private$.acting_address())}\if{html}{\out{</div>}}
}

\subsection{Arguments}{
\if{html}{\out{<div class="arguments">}}
\describe{
\item{\code{address}}{Character; the account's \verb{0x}-prefixed address. Defaults to
the instance's acting address.}
}
\if{html}{\out{</div>}}
}
\subsection{Returns}{
A \link[data.table:data.table]{data.table::data.table} with \code{vault_address}, \code{equity},
\code{locked_until_timestamp}, or a promise thereof.
}
}
